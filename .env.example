# Database Configuration
# Ganti dengan detail koneksi database Anda
DATABASE_URL="mysql+aiomysql://username:password@localhost:3306/db_neuropalm"

# Security Configuration
SECRET_KEY="ganti_dengan_key_yang_sangat_kuat_dan_panjang"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Argon2 Password Hashing Parameters
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=102400
ARGON2_PARALLELISM=8
ARGON2_HASH_LEN=16

# CLIP Configuration
CLIP_THRESHOLD=0.60
